{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://net-rga.dev/schemas/benchmark_result.schema.json",
  "title": "Net-RGA Benchmark Result Report",
  "description": "Machine-readable output for a benchmark run, including per-query results and aggregate metrics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "corpus_id",
    "tool_revision",
    "run_mode",
    "query_results",
    "aggregate_metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "suite_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "corpus_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._/-]{2,255}$"
    },
    "tool_revision": {
      "$ref": "#/$defs/tool_revision"
    },
    "run_mode": {
      "$ref": "#/$defs/run_mode"
    },
    "query_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/query_result"
      }
    },
    "aggregate_metrics": {
      "$ref": "#/$defs/aggregate_metrics"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    }
  },
  "$defs": {
    "tool_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "dirty"
      ],
      "properties": {
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "run_mode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_mode",
        "manifest_state",
        "content_cache_state",
        "backend_mode"
      ],
      "properties": {
        "provider_mode": {
          "type": "string",
          "enum": [
            "local_fs",
            "s3_compatible",
            "s3",
            "corpus_default"
          ]
        },
        "manifest_state": {
          "type": "string",
          "enum": [
            "cold",
            "warm",
            "stale",
            "imported_bundle"
          ]
        },
        "content_cache_state": {
          "type": "string",
          "enum": [
            "cold",
            "warm",
            "not_applicable"
          ]
        },
        "backend_mode": {
          "type": "string",
          "enum": [
            "disabled",
            "enabled",
            "corpus_default"
          ]
        },
        "network_profile": {
          "type": "string",
          "enum": [
            "default",
            "throttled",
            "not_applicable"
          ]
        }
      }
    },
    "query_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "status",
        "latency_ms",
        "cost_counters",
        "correctness",
        "coverage"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "error"
          ]
        },
        "latency_ms": {
          "$ref": "#/$defs/latency_metrics"
        },
        "cost_counters": {
          "$ref": "#/$defs/cost_counters"
        },
        "correctness": {
          "$ref": "#/$defs/correctness_metrics"
        },
        "coverage": {
          "$ref": "#/$defs/coverage_metrics"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "latency_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total"
      ],
      "properties": {
        "total": {
          "type": "number",
          "minimum": 0
        },
        "first_candidate": {
          "type": "number",
          "minimum": 0
        },
        "first_verified_match": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "cost_counters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "list_calls",
        "stat_calls",
        "read_calls",
        "bytes_fetched"
      ],
      "properties": {
        "list_calls": {
          "type": "integer",
          "minimum": 0
        },
        "stat_calls": {
          "type": "integer",
          "minimum": 0
        },
        "read_calls": {
          "type": "integer",
          "minimum": 0
        },
        "bytes_fetched": {
          "type": "integer",
          "minimum": 0
        },
        "extracted_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "correctness_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_match",
        "anchor",
        "coverage_summary"
      ],
      "properties": {
        "exact_match": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not_applicable"
          ]
        },
        "anchor": {
          "type": "string",
          "enum": [
            "pass",
            "nearby",
            "fail",
            "not_applicable"
          ]
        },
        "snippet": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not_applicable"
          ]
        },
        "coverage_summary": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        }
      }
    },
    "coverage_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reported_status",
        "coverage_correct"
      ],
      "properties": {
        "reported_status": {
          "type": "string",
          "enum": [
            "complete",
            "partial"
          ]
        },
        "coverage_correct": {
          "type": "boolean"
        },
        "deleted_count": {
          "type": "integer",
          "minimum": 0
        },
        "denied_count": {
          "type": "integer",
          "minimum": 0
        },
        "stale_count": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_count": {
          "type": "integer",
          "minimum": 0
        },
        "failure_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "aggregate_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_count",
        "pass_count",
        "fail_count",
        "error_count",
        "latency_ms",
        "cost_counters"
      ],
      "properties": {
        "query_count": {
          "type": "integer",
          "minimum": 0
        },
        "pass_count": {
          "type": "integer",
          "minimum": 0
        },
        "fail_count": {
          "type": "integer",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "latency_ms": {
          "$ref": "#/$defs/aggregate_latency_metrics"
        },
        "cost_counters": {
          "$ref": "#/$defs/cost_counters"
        }
      }
    },
    "aggregate_latency_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p50_total",
        "p95_total"
      ],
      "properties": {
        "p50_total": {
          "type": "number",
          "minimum": 0
        },
        "p95_total": {
          "type": "number",
          "minimum": 0
        },
        "p50_first_verified_match": {
          "type": "number",
          "minimum": 0
        },
        "p95_first_verified_match": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
